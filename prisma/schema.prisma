// Security Awareness Platform - Prisma Schema
// Production-ready database schema with all core entities
// Multi-tenancy Organization Model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ModuleCategory {
  PHISHING
  PASSWORDS
  SOCIAL_ENGINEERING
  MALWARE
  BROWSING
  MOBILE
  NETWORK
  DATA_PROTECTION
  COMPLIANCE
  GENERAL
}

enum LessonType {
  VIDEO
  READING
  INTERACTIVE
  SIMULATION
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignType {
  TRAINING
  PHISHING_SIMULATION
  ASSESSMENT
  AWARENESS
}

enum ContactStatus {
  NEW
  IN_REVIEW
  CONTACTED
  CLOSED
}

enum ActivityType {
  MODULE_STARTED
  MODULE_COMPLETED
  QUIZ_COMPLETED
  QUIZ_FAILED
  BADGE_EARNED
  CERTIFICATE_EARNED
  LOGIN
  PROFILE_UPDATED
  CAMPAIGN_ASSIGNED
  PHISHING_REPORTED
}

enum BadgeColor {
  BLUE
  GREEN
  PURPLE
  GOLD
  RED
  CYAN
}

enum OrganizationPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}


enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

// ============================================
// ORGANIZATION (Multi-Tenancy)
// ============================================

model Organization {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  domain        String?            @unique
  plan          OrganizationPlan   @default(FREE)
  logo          String?
  maxUsers      Int                @default(50)
  status        OrganizationStatus @default(ACTIVE)
  billingEmail  String?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  currentUsers  Int                @default(0)
  notes         String?            @db.Text
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?
  users         User[]
  departments   Department[]
  modules       Module[]
  quizzes       Quiz[]
  campaigns     Campaign[]
  badges        Badge[]
  phishingExamples PhishingExample[]
  settings      OrgSetting[]
  invitations   Invitation[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  @@index([slug])
  @@index([domain])
}

model Invitation {
  id               String    @id @default(cuid())
  email            String
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role             UserRole  @default(EMPLOYEE)
  token            String    @unique @default(cuid())
  expiresAt        DateTime
  acceptedAt       DateTime?
  invitedBy        String
  createdAt        DateTime  @default(now())
  @@unique([email, organizationId])
  @@index([token])
  @@index([organizationId])
}

model OrgSetting {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key              String
  value            String
  updatedAt        DateTime     @updatedAt
  @@unique([organizationId, key])
  @@index([organizationId])
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  passwordHash  String
  role          UserRole    @default(EMPLOYEE)
  status        UserStatus  @default(ACTIVE)
  avatar        String?
  phone         String?
  jobTitle      String?
  riskScore     Float       @default(50)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])

  // Relations
  moduleProgress  ModuleProgress[]
  lessonProgress  LessonProgress[]
  quizResults     QuizResult[]
  badges          UserBadge[]
  certificates    Certificate[]
  activities      Activity[]
  campaignUsers   CampaignUser[]
  quizAssignments QuizAssignment[]

  // Audit fields
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([email])
  @@index([role])
  @@index([departmentId])
  @@index([status])
  @@index([organizationId])
}

model Department {
  id              String    @id @default(cuid())
  name            String
  description     String?
  employeeCount   Int       @default(0)
  averageScore    Float     @default(0)
  riskScore       Float     @default(50)
  completionRate  Float     @default(0)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  // Relations
  users             User[]
  quizDepartments   QuizDepartment[]
  campaignDepartments CampaignDepartment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ============================================
// TRAINING MODULES
// ============================================

model Module {
  id            String          @id @default(cuid())
  title         String
  description   String
  category      ModuleCategory
  difficulty    Difficulty
  durationMins  Int             @default(30)
  imageUrl      String?
  isPublished   Boolean         @default(true)
  isGlobal      Boolean         @default(false)
  order         Int             @default(0)
  organizationId String?
  organization  Organization?   @relation(fields: [organizationId], references: [id])

  // Relations
  lessons         Lesson[]
  quiz            Quiz?           @relation("ModuleQuiz")
  moduleProgress  ModuleProgress[]
  campaignModules CampaignModule[]
  keyTakeaways    String[]        @default([])
  realExamples    String[]        @default([])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([organizationId])
}

model Lesson {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        LessonType
  content     String?     @db.Text
  durationMins Int        @default(10)
  order       Int         @default(0)
  moduleId    String
  module      Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Progress tracking
  lessonProgress LessonProgress[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([moduleId])
}

model ModuleProgress {
  id            String    @id @default(cuid())
  userId        String
  moduleId      String
  progress      Float     @default(0)  // 0-100
  isCompleted   Boolean   @default(false)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module        Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

// ============================================
// QUIZZES & ASSESSMENTS
// ============================================

model Quiz {
  id            String      @id @default(cuid())
  title         String
  description   String?
  moduleId      String?     @unique
  module        Module?     @relation("ModuleQuiz", fields: [moduleId], references: [id], onDelete: SetNull)
  difficulty    Difficulty  @default(INTERMEDIATE)
  category      ModuleCategory @default(GENERAL)
  passingScore  Int         @default(70)  // percentage
  timeLimitMins Int?        @default(15)
  status        QuizStatus  @default(DRAFT)
  isCustom      Boolean     @default(false)
  dueDate       DateTime?
  visibleFrom   DateTime?
  visibleUntil  DateTime?
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])

  // Relations
  questions       Question[]
  results         QuizResult[]
  quizDepartments QuizDepartment[]
  quizAssignments QuizAssignment[]
  campaignQuizzes CampaignQuiz[]

  createdBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([moduleId])
  @@index([isCustom])
  @@index([organizationId])
}

model Question {
  id            String    @id @default(cuid())
  quizId        String
  quiz          Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  explanation   String?
  order         Int       @default(0)
  options       QuestionOption[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([quizId])
}

model QuestionOption {
  id          String    @id @default(cuid())
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text        String
  isCorrect   Boolean   @default(false)
  order       Int       @default(0)

  @@index([questionId])
}

model QuizResult {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  score       Float
  passed      Boolean
  answers     Json      // Store answer details as JSON
  timeTaken   Int?      // seconds
  attemptNum  Int       @default(1)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([quizId])
  @@index([userId, quizId])
}

model QuizDepartment {
  id            String      @id @default(cuid())
  quizId        String
  departmentId  String
  quiz          Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assignedAt    DateTime    @default(now())

  @@unique([quizId, departmentId])
  @@index([quizId])
  @@index([departmentId])
}

model QuizAssignment {
  id        String    @id @default(cuid())
  quizId    String
  userId    String
  quiz      Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dueDate   DateTime?
  assignedAt DateTime @default(now())

  @@unique([quizId, userId])
  @@index([quizId])
  @@index([userId])
}

// ============================================
// CAMPAIGNS
// ============================================

model Campaign {
  id              String          @id @default(cuid())
  name            String
  description     String?
  type            CampaignType
  status          CampaignStatus  @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  completionRate  Float           @default(0)
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id])

  // Relations
  campaignModules     CampaignModule[]
  campaignUsers       CampaignUser[]
  campaignDepartments CampaignDepartment[]
  campaignQuizzes     CampaignQuiz[]

  createdBy       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([type])
  @@index([organizationId])
}

model CampaignModule {
  id          String    @id @default(cuid())
  campaignId  String
  moduleId    String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([campaignId, moduleId])
}

model CampaignUser {
  id          String    @id @default(cuid())
  campaignId  String
  userId      String
  isCompleted Boolean   @default(false)
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
}

model CampaignDepartment {
  id            String      @id @default(cuid())
  campaignId    String
  departmentId  String
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([campaignId, departmentId])
}

model CampaignQuiz {
  id          String    @id @default(cuid())
  campaignId  String
  quizId      String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([campaignId, quizId])
}

// ============================================
// GAMIFICATION
// ============================================

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  icon        String      @default("Award")
  color       BadgeColor  @default(BLUE)
  criteria    String?     // Description of how to earn
  isGlobal    Boolean     @default(false)
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])

  // Relations
  userBadges  UserBadge[]

  createdAt   DateTime    @default(now())

  @@unique([organizationId, name])
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeId   String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime  @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model Certificate {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String?
  moduleName  String
  quizScore   Float?
  issuedAt    DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// PHISHING SIMULATIONS
// ============================================

model PhishingExample {
  id          String      @id @default(cuid())
  subject     String
  sender      String
  senderEmail String
  body        String      @db.Text
  redFlags    String[]    @default([])
  difficulty  Difficulty
  category    String      @default("email")
  isActive    Boolean     @default(true)
  isGlobal    Boolean     @default(false)
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])

  createdAt   DateTime    @default(now())

  @@index([organizationId])
}

// ============================================
// ACTIVITY & AUDIT
// ============================================

model Activity {
  id          String        @id @default(cuid())
  userId      String
  type        ActivityType
  target      String        // What was acted upon
  details     String?       // Additional info
  ipAddress   String?

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ============================================
// CONTACT / DEMO REQUESTS
// ============================================

model ContactRequest {
  id            String        @id @default(cuid())
  name          String
  email         String
  company       String?
  phone         String?
  message       String        @db.Text
  status        ContactStatus @default(NEW)
  internalNotes String?       @db.Text
  reviewedBy    String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ============================================
// SETTINGS
// ============================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt
  
  @@index([key])
}
